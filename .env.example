# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Your project's public API URL
NEXT_PUBLIC_SUPABASE_URL=

# Anon/public key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-only, NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=


# ─── Google Gemini ────────────────────────────────────────────────────────────
# Found in: https://aistudio.google.com → API keys

GEMINI_API_KEY=


# ─── SMTP (Email via Gmail) ───────────────────────────────────────────────────
# Use a Gmail App Password — NOT your regular Gmail password.
# How to create one: Google Account → Security → 2-Step Verification → App Passwords

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=                            # e.g. kishautodetailing@gmail.com
SMTP_PASS=                            # 16-char App Password (no spaces)


# ─── App ──────────────────────────────────────────────────────────────────────
# The owner's email address — receives escalation notifications from the chatbot
ADMIN_EMAIL=

# Public URL of the deployed app. Used to build booking tracking links in emails.
# Leave blank for local dev (defaults to http://localhost:3000)
NEXT_PUBLIC_APP_URL=

# Optional Google Maps embed URL for the Location page.
# Generate at: https://www.google.com/maps/embed — leave blank to hide the map.
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_URL=
